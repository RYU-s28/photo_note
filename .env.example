VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
VISION_KEY=your-azure-vision-key
VISION_LANGUAGE=en

API_PORT=8787
MAX_IMAGE_BYTES=10485760

# Comma-separated CORS allowlist for deployed frontend origins.
# For GitHub Pages at https://your-user.github.io/photo_note/ use:
# CORS_ALLOW_ORIGINS=https://your-user.github.io
CORS_ALLOW_ORIGINS=

# Frontend build-time API base URL for static hosting such as GitHub Pages.
# Leave empty for local dev, where Vite proxies /api to the local Express server.
VITE_API_BASE_URL=